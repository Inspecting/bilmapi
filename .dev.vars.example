# Copy this file to `.dev.vars` for local Wrangler dev.
# Do not commit real secrets.

FIREBASE_PROJECT_ID=bilm-7bfe1
BILM_DISABLE_AUTH=false
# Optional temporary bypass secret for local-only testing.
# Auth bypass is disabled unless BOTH BILM_DISABLE_AUTH=true and this token is set.
BILM_AUTH_BYPASS_TOKEN=replace-with-local-bypass-token

# Supabase mirror config (data-api backend)
# Either SUPABASE_PROJECT_URL or SUPABASE_URL works in this codebase.
SUPABASE_PROJECT_URL=https://veoydbjuggetxwfgryzc.supabase.co
SUPABASE_URL=https://veoydbjuggetxwfgryzc.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_********************
SUPABASE_MIRROR_ENABLED=true
SUPABASE_MIRROR_TABLE=cloudflare_mirror_events
SUPABASE_MIRROR_TIMEOUT_MS=10000
